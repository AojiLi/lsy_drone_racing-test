{
  "schema_version": 1,
  "lane": "v55_tracker_qualification_curriculum",
  "purpose": "Completion gates for the Level3 low-level PPO reference tracker. The required ladder proves free-space trajectory tracking, then moves directly to planner integration smoke. Gate-aperture reference is optional diagnostic only.",
  "hard_boundary": {
    "final_eval_config": "config/level3.toml",
    "target_track_mutable": false,
    "free_space_training_config": "config/level3_tracker_free_space.toml",
    "gate_aperture_training_config": "config/level3_tracker_gate_aperture.toml"
  },
  "common_rules": {
    "checkpoint_backed_required": true,
    "all_finite_required": true,
    "generated_artifacts_in_git": false,
    "stage_gate_semantics": "all required_metrics must pass before next_stage is unlocked for required stages; optional_diagnostic stages do not block planner_integration_smoke"
  },
  "training_policy": {
    "short_smoke_purpose": "Only verify command plumbing, W&B, checkpoint writing, evaluator loading, finite observations/actions, and gate-checker behavior.",
    "smoke_timesteps_max": 100000,
    "do_not_judge_learning_from_smoke": true,
    "learning_failure_requires_maturation_chunk": true,
    "allowed_smoke_failure_reasons": [
      "nan_or_non_finite_action",
      "nan_or_non_finite_observation",
      "trainer_exception",
      "evaluator_exception",
      "checkpoint_metadata_invalid",
      "config_level3_toml_changed"
    ],
    "milestone_eval_required": true,
    "default_maturation_is_not_failure_ceiling": true,
    "research_backed_budget_memory": {
      "simple_quadrotor_tracking_floor": "1M environment steps is a small-task/default floor, not enough to reject a tracker skill when metrics are still improving.",
      "reference_tracker_range": "15M-50M environment interactions is common for published quadrotor trajectory-tracking or agile-control PPO-style work.",
      "full_racing_or_obstacle_generalization_range": "100M+ environment interactions is common for full racing, obstacle-rich, vision, or broad generalization policies."
    },
    "parallel_rollout_policy": {
      "single_env_training_allowed": false,
      "default_num_envs": 1024,
      "default_num_steps": 32,
      "default_batch_size": 32768,
      "level2_precedent": "Earlier successful PPO training used 1024 parallel envs with 32-step rollouts for 32768 samples per update.",
      "longer_horizon_variant": {
        "num_envs": 256,
        "num_steps": 128,
        "batch_size": 32768,
        "use_when": "Use after a decision packet if 1024x32 shows insufficient credit horizon for trajectory tracking."
      }
    },
    "extension_rule": "If a stage misses its gate after default maturation but milestone checkpoints or W&B curves are still improving, prefer a same-stage extension chunk after the three-review decision packet instead of immediately changing reward, observation, PPO structure, or declaring the stage failed.",
    "budget_review_rule": "If changing stage budgets or rejecting a stage for undertraining, run a research/budget review against papers, GitHub configs, W&B curves, and local milestone curves before the decision packet."
  },
  "stages": [
    {
      "id": "hover",
      "order": 1,
      "environment": "free_space",
      "config": "config/level3_tracker_free_space.toml",
      "task": "hover",
      "training_budget": {
        "preflight_smoke_timesteps": 4096,
        "default_maturation_timesteps": 1000000,
        "research_extension_timesteps": 5000000,
        "min_timesteps_before_learning_failure": 1000000,
        "checkpoint_interval_timesteps": 250000,
        "evaluate_all_milestones": true
      },
      "min_eval_episodes": 20,
      "next_stage": "point_hold",
      "required_metrics": [
        {"name": "checkpoint_backed", "op": "==", "value": true},
        {"name": "all_finite", "op": "==", "value": true},
        {"name": "success_rate", "op": ">=", "value": 0.95},
        {"name": "crash_rate", "op": "<=", "value": 0.02},
        {"name": "mean_position_error_m", "op": "<=", "value": 0.12},
        {"name": "p90_position_error_m", "op": "<=", "value": 0.2},
        {"name": "mean_speed_mps", "op": "<=", "value": 0.15},
        {"name": "mean_action_delta_l2", "op": "<=", "value": 0.22}
      ]
    },
    {
      "id": "point_hold",
      "order": 2,
